    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n\nconst AUTH_KEY = $node[\"Set Inputs\"].json.AUTH_KEY || '';\nconst AUTH_SECRET = $node[\"Set Inputs\"].json.AUTH_SECRET || '';\nconst OCR_PROVIDER = ($node[\"Set Inputs\"].json.OCR_PROVIDER || 'gcp').trim(); // 'gcp' or 'aws'\n\nif (!AUTH_KEY) throw new Error('Missing AUTH_KEY');\nif (!AUTH_SECRET) throw new Error('Missing AUTH_SECRET');\n\nif (!['gcp', 'aws'].includes(OCR_PROVIDER)) {\n  throw new Error(`Invalid OCR_PROVIDER: ${OCR_PROVIDER}. Use \"gcp\" or \"aws\".`);\n}\n\nconst inputItem = $input.first();\nconst inputBinary = inputItem.binary || {};\nif (!inputBinary.data) throw new Error('No binary.data found coming into Code node');\n\nconst expires = new Date(Date.now() + 5 * 60 * 1000).toISOString();\n\nconst paramsObj = {\n  auth: { key: AUTH_KEY, expires },\n  steps: {\n    ':original': { robot: '/upload/handle' },\n\n    // PDF -> one PNG per page (meta.thumb_index preserved)\n    'pdf-pages': {\n      use: ':original',\n      robot: '/document/thumbs',\n      format: 'png',\n      density: '300',\n    },\n\n    // OCR per page image; results stored in meta.recognized_text\n    'ocr-pages': {\n      use: 'pdf-pages',\n      robot: '/image/ocr',\n      provider: OCR_PROVIDER,\n      format: 'meta',\n      ignore_errors: ['execute'],\n    },\n  },\n};\n\nconst params = JSON.stringify(paramsObj);\nconst signature = crypto\n  .createHmac('sha1', AUTH_SECRET)\n  .update(params)\n  .digest('hex');\n\nreturn {\n  json: {\n    transloadit_params: params,\n    transloadit_signature: signature,\n  },\n  binary: inputBinary,\n};"
      },
      "id": "d553dad5-5001-489e-90ee-bf6640e8d7e7",
      "name": "Build Transloadit Params + Signature",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1088,
        -48
      ]
    },
    {
      "parameters": {
        "jsCode": "const inputItems = $input.all();\nif (!inputItems.length) throw new Error('No input items');\n\nconst assembly = inputItems[0].json;\nconst OCR_STEP = 'ocr-pages';\n\nconst ocrPages = assembly?.results?.[OCR_STEP];\nif (!Array.isArray(ocrPages) || ocrPages.length === 0) {\n  throw new Error(`No results found at assembly.results[\"${OCR_STEP}\"]`);\n}\n\nfunction firstNonEmpty(...values) {\n  for (const v of values) {\n    if (v !== undefined && v !== null && v !== '') return v;\n  }\n  return undefined;\n}\n\nfunction decodeIfEncoded(value) {\n  if (typeof value !== 'string') return value;\n  if (!/%[0-9A-Fa-f]{2}/.test(value)) return value;\n  try {\n    return decodeURIComponent(value);\n  } catch {\n    return value;\n  }\n}\n\nfunction normalizeText(text) {\n  return String(text)\n    .replace(/\\s+([,.;:!?])/g, '$1')\n    .replace(/([(\\[])\\s+/g, '$1')\n    .replace(/\\s+([)\\]])/g, '$1')\n    .replace(/\\s{2,}/g, ' ')\n    .trim();\n}\n\nfunction getThumbIndex(page, fallbackIndex) {\n  const n = Number(page?.meta?.thumb_index);\n  return Number.isFinite(n) ? n : fallbackIndex;\n}\n\nfunction extractMetadata(pages) {\n  const meta = pages?.[0]?.meta || {};\n  return {\n    Title: decodeIfEncoded(firstNonEmpty(meta.Title, meta.title, meta['pdf:Title'], meta['dc:title'])),\n    CreationDate: firstNonEmpty(\n      meta.CreationDate,\n      meta.creation_date,\n      meta.create_date,\n      meta.creationDate,\n      meta['pdf:CreationDate'],\n      meta['xmp:CreateDate'],\n      meta['CreateDate']\n    ),\n    ModDate: firstNonEmpty(\n      meta.ModDate,\n      meta.mod_date,\n      meta.modify_date,\n      meta.modifyDate,\n      meta.modDate,\n      meta['pdf:ModDate'],\n      meta['xmp:ModifyDate'],\n      meta['ModifyDate']\n    ),\n    Author: firstNonEmpty(meta.Author, meta.author, meta['dc:creator']),\n    Producer: firstNonEmpty(meta.Producer, meta.producer),\n    Creator: firstNonEmpty(meta.Creator, meta.creator),\n    page_count: firstNonEmpty(meta.page_count, meta.pageCount),\n  };\n}\n\nfunction pageToText(page) {\n  const recognized = page?.meta?.recognized_text;\n\n  if (typeof recognized === 'string') {\n    return normalizeText(recognized);\n  }\n\n  if (!Array.isArray(recognized) || recognized.length === 0) return '';\n\n  const texts = recognized\n    .map(item => (typeof item?.text === 'string' ? item.text.trim() : ''))\n    .filter(Boolean);\n\n  if (texts.length === 0) return '';\n\n  const LONG_MIN_CHARS = 40;\n  const longish = texts.filter(t => t.length >= LONG_MIN_CHARS);\n\n  let combined;\n  if (longish.length >= 3) {\n    combined = longish.join('\\n');\n  } else {\n    combined = texts.join(' ');\n  }\n\n  combined = combined.replace(/\\s*[•·]\\s*/g, '\\n• ');\n\n  return normalizeText(combined)\n    .replace(/\\n{3,}/g, '\\n\\n')\n    .trim();\n}\n\nconst sortedPages = ocrPages\n  .map((page, idx) => ({ page, order: getThumbIndex(page, idx) }))\n  .sort((a, b) => a.order - b.order);\n\nconst pageTexts = [];\nconst missingPages = [];\n\nfor (const { page, order } of sortedPages) {\n  const text = pageToText(page);\n  if (text) pageTexts.push(text);\n  else missingPages.push(order);\n}\n\nconst mergedText = pageTexts.join('\\n\\n');\nconst metadata = extractMetadata(ocrPages);\n\nreturn [\n  {\n    json: {\n      data: mergedText,\n      metadata,\n      missing_pages: missingPages,\n      assembly_id: assembly?.assembly_id || assembly?.id || null,\n    },\n  },\n];"
      },
